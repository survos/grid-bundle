{
  "name": "@survos/grid",
  "description": "integrate php and javascript helpers for DataTables.net",
  "license": "MIT",
  "version": "1.0.3",
  "symfony": {
    "controllers": {
      "grid": {
        "main": "src/controllers/grid_controller.js",
        "webpackMode": "eager",
        "fetch": "lazy",
        "enabled": true,
        "autoimport": {
          "datatables.net-buttons-bs5/css/buttons.bootstrap5.min.css": true,
          "datatables.net-responsive-bs5/css/responsive.bootstrap5.min.css": true,
          "datatables.net-scroller-bs5/css/scroller.bootstrap5.min.css": true,
          "datatables.net-searchpanes-bs5/css/searchPanes.bootstrap5.min.css": true,
          "datatables.net-select-bs5/css/select.bootstrap5.min.css": true,
          "datatables.net-bs5/css/dataTables.bootstrap5.min.css": true
        }
      }
    },
    "importmap": {
      "@hotwired/stimulus": "^3.2.2",
      "@popperjs/core": "^2.11.8",
      "bootstrap": "^5.3.8",
      "datatables.net-plugins/i18n/en-GB.mjs": "^2.3.7",
      "datatables.net-bs5": "^2.3.7",
      "datatables.net-buttons-bs5": "^3.2.6",
      "datatables.net-select-bs5": "^3.1.3",
      "datatables.net-scroller-bs5": "^2.4.3",
      "datatables.net-responsive-bs5": "^3.0.8",
      "datatables.net-searchpanes-bs5": "^2.3.5"
    }
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.2.0"
  },
