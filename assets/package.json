    "@hotwired/stimulus": "^3.2.2"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "datatables.net-buttons-bs5": "^3.2",
    "datatables.net-colreorder": "^2.1.2",
    "datatables.net-colreorder-bs5": "^2.1.2",
    "datatables.net-datetime": "^1.6.3",
    "datatables.net-fixedcolumns-bs5": "^5.0.5",
    "datatables.net-fixedheader-bs5": "^4.0.6",
    "datatables.net-responsive": "^3.0.8",
    "datatables.net-responsive-bs5": "^3.0.8",
    "datatables.net-scroller": "^2.4.3",
    "datatables.net-scroller-bs5": "^2.4.3",
    "bootstrap": "^5.3.8"
