{
    "name": "survos/grid-bundle",
    "description": "incorporate DatatablesNet, using twig and stimulus, twig_component requires ^2.3",
    "keywords": [
        "symfony-ux",
        "symfony6"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/orm": "^3.3",
        "doctrine/persistence": "^4.1",
        "survos/core-bundle": "^2.5",
        "survos/kit-bundle": "^2.5",
        "symfony/config": "^7.3||^8.0",
        "symfony/dependency-injection": "^7.3||^8.0",
        "symfony/http-kernel": "^7.3||^8.0",
        "symfony/options-resolver": "^7.3||^8.0",
        "symfony/ux-twig-component": "^2.0|^3.0",
        "twig/twig": "^3.4",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/property-access": "^7.3||^8.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^7.3||^8.0",
        "symfony/framework-bundle": "^7.3||^8.0",
        "symfony/phpunit-bridge": "^7.3||^8.0",
        "symfony/twig-bundle": "^7.3||^8.0",
        "symfony/var-dumper": "^7.3||^8.0"
    },
    "autoload": {
        "psr-4": {
            "Survos\\Grid\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.6-dev"
        },
        "symfony": {
            "require": "^7.3"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse"
    },
    "suggest": {
        "monolog/monolog": "Allows more advanced logging of the application flow",
        "survos/api-grid-bundle": "For javascript-based grid rendering"
    },
    "prefer-stable": true
}